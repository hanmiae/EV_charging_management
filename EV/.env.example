# =============================================================================
# Frontend environment (Vite). Copy to `.env.local` for local dev, and set the
# same variables in Vercel Project Settings -> Environment Variables for prod.
# =============================================================================

# Optional explicit API base. Leave empty when you want both local Vite and
# Vercel production to use relative `/api/*` requests with proxy/rewrite rules.
VITE_API_BASE=

# Optional explicit media base. Defaults to VITE_API_BASE when omitted.
# Use this only if `/images/*` is served from a different host than `/api/*`.
VITE_MEDIA_BASE_URL=

# Local-only Vite proxy target for `/api/*` and `/images/*`.
VITE_DEV_BACKEND_URL=http://localhost:8080

# Optional public CCTV/MJPEG endpoints. Leave blank to fall back to the backend
# snapshot/image URLs returned by `/api/dashboard`.
VITE_STREAM_A01=
VITE_STREAM_A02=
VITE_STREAM_B01=
VITE_STREAM_B02=
